<% layout("/layouts/boilerplate")%>
        <style>
            .edit-btn,
          .delete-btn,
.save-btn{
    min-width: 90px;
}

@media(max-width:768px){

    .edit-btn,
    .delete-btn,
    .save-btn{
        width:100px;
    }
}
        </style>
    
        <div class="row mt-2">
            <div class="col-12 col-md-8 mx-auto"> 
                <h3>
                    <%=show.title%>
                </h3>
            </div>
            <div class="card listing-card col-12  col-md-8 mx-auto show-card">
                <img src="<%=show.image.url%>" class="card-img-top show-img" alt="listing_image" />
                <div class="card-body">
                    <p class="card-text mt-2">
                        @<%=show.owner.username%>
                    </p>

                    <p class="card-text">
                        <%=show.description%>
                    </p>
                    <p class="card-text">&#8377;<%=show.price.toLocaleString("en-IN")%></p>
                    <p class="card-text">
                        <%=show.location%>
                    </p>
                    <p class="card-text">
                        <%=show.country%>
                    </p>

                </div>
            </div>
            <div class="d-flex gap-2 flex-wrap justify-content-center my-3">
            <%if(currUser && currUser._id.equals(show.owner._id)){%>
                
                    <a href="/listings/<%=show._id%>/edit" class="btn btn-dark edit-btn">Edit</a>

                    <form method="post" action="/listings/<%=show._id%>?_method=Delete" class="d-inline">
                        <button class="btn btn-dark  delete-btn">Delete</button>
                    </form>
                <%}else{%>
                    <div style="width:320px;"></div>  
                
                <%}%>
                 <%if(currUser){%>
                <form method="post" action="/listings/wishlist/<%=show._id%>"class="d-inline ">
                        <button class="btn btn-danger  save-btn">Save</button>
                 </form>
                <%}%> 
                </div>
                    <div class="col-12 col-md-8 mx-auto mb-3">
                        <hr>
                        <%if(currUser){%>
                            <h4>Leave Review</h4>
                            <form method="post" action="/listings/<%=show._id%>/reviews" novalidate
                                class="needs-validation">

                                <div class="mt-3 mb-3">
                                    <label for="rating">Rating</label>
                                    <fieldset class="starability-heartbeat">

                                        <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]"
                                            value="1" checked aria-label="No rating." />
                                        <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                                        <label for="first-rate1" title="Terrible">1 star</label>
                                        <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                                        <label for="first-rate2" title="Not good">2 stars</label>
                                        <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                                        <label for="first-rate3" title="Average">3 stars</label>
                                        <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                                        <label for="first-rate4" title="Very good">4 stars</label>
                                        <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                                        <label for="first-rate5" title="Amazing">5 stars</label>
                                    </fieldset>
                                </div>
                                <div class="mt-3 mb-3">
                                    <lebel for="Comments" class="form-label">Comments</lebel>
                                    <textarea name="review[comment]" id="comment" class="form-control" cols="30"
                                        rows="5" required></textarea>
                                    <div class="invalid-feedback">please add some cooments for review </div>
                                </div>
                                <button class="btn btn-outline-dark">Submit</button>
                            </form>
                            <hr>
                            <%}%>
                                <%if(show.reviews.length>0){%>
                                <div class="row">
                                    <p><b>All Reviews</b></p>
                                    <% for(review of show.reviews) { %>
                                        <div class="card col-12 col-md-5  ms-md-3 mb-3">
                                            <div class="card-body">
                                                <h5 class="card-title">@<%=review.author.username%>
                                                </h5>
                                                <p class="starability-result card-text"
                                                    data-rating="<%=review.rating%>"></p>
                                                <p class="card-text">
                                                    <%=review.comment%>
                                                </p>
                                                <%if(currUser && currUser._id.equals(review.author._id)){%>
                                                <form method="post"
                                                    action="/listings/<%=show._id%>/reviews/<%=review._id%>?_method=Delete">
                                                    <button class="btn btn-sm btn-dark mb-2">Delete</button>
                                                </form>
                                                <%}%>
                                            </div>

                                        </div>
                                        <% } %>
                                </div>
                                <%}%>
                                
                    </div>
                    <div class="col-12 col-md-8 mx-auto mb-3">
                    <h3 >Where you will be</h3>  
                    <div id="map" >
                                   
                    </div>
                    </div>

                   
        </div>

        <script>
        const coordinates=<%-JSON.stringify(show.geometry.coordinates)%>;
         const hotelTitle = <%- JSON.stringify(show.title) %>;
         const hotelLocation = <%- JSON.stringify(show.location) %>;
        </script>

        
    