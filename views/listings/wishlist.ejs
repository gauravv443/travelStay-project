<% layout("/layouts/boilerplate") %>

<h2 class="mt-3"> My Wishlist</h2>

<div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1">

    <% if(wishlist.length === 0) { %>

        <h4>No saved listings yet</h4>

    <% } %>

    <% for(let listing of wishlist) { %>

        <div class="card col listing-card m-3">

            <img
                src="<%= listing.image.url %>"
                class="card-img-top"
                alt="listing image"
            >

            <div class="card-body">

                <h5 class="card-title">
                    <%= listing.title %>
                </h5>

                <p class="card-text">
                    <%= listing.location %>
                </p>

                <p class="card-text">
                    &#8377;<%=listing.price.toLocaleString("en-IN")%>/night
                </p>
                <div class="d-flex gap-2 mt-2">
                <a
                    href="/listings/<%= listing._id %>"
                    class="btn btn-dark"
                >
                    View Listing
                </a>
                <form
                   action="/listings/wishlist/<%= listing._id %>?_method=DELETE"
                   method="POST"
                >

                <button class="btn btn-danger">
                       Remove
                </button>

                 </form>
                </div>
            </div>

        </div>

    <% } %>

</div>